{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.legolev/mediamcp",
  "description": "Generate and edit images and video via OpenRouter or any OpenAI-compatible API.",
  "repository": {
    "url": "https://github.com/legolev/mediamcp",
    "source": "github"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mediamcp",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "OPENROUTER_API_KEY",
          "description": "OpenRouter API key (https://openrouter.ai/keys)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "MEDIAMCP_OUTPUT_DIR",
          "description": "Directory for generated files (default: ~/Pictures/mediamcp)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "MEDIAMCP_MODEL",
          "description": "Default image model slug (default: google/gemini-2.5-flash-image)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
