# mediamcp — local development only.
# In real MCP clients, pass these via the "env" block of the client config instead.

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional overrides (defaults shown):
# MEDIAMCP_API_KEY=            # generic key alias, wins over OPENROUTER_API_KEY
# MEDIAMCP_BASE_URL=https://openrouter.ai/api/v1
# MEDIAMCP_MODEL=google/gemini-2.5-flash-image
# MEDIAMCP_VIDEO_MODEL=google/veo-3.1
# MEDIAMCP_OUTPUT_DIR=~/Pictures/mediamcp
# MEDIAMCP_TIMEOUT_MS=120000
# MEDIAMCP_PREVIEW=true
# MEDIAMCP_PREVIEW_MAX_DIM=768
# MEDIAMCP_REFERER=https://github.com/legolev/mediamcp
# MEDIAMCP_TITLE=mediamcp
